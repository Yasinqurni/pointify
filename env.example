# Private key for deployment (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# Lisk API key for contract verification (optional)
LISK_API_KEY=your_lisk_api_key_here

# Network configuration
NETWORK=lisk-sepolia

# Platform fee in basis points (200 = 2%)
PLATFORM_FEE=200

# Fee recipient address
FEE_RECIPIENT=0x0000000000000000000000000000000000000000

# ============================================================
# DEPLOYED CONTRACT ADDRESSES - Pointify Loyalty v3
# ============================================================

# ERC20Mock (IDRX Token)
IDRX_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000

# RewardManager Contract
REWARD_MANAGER_ADDRESS=0x0000000000000000000000000000000000000000

# RedemptionRouter Contract
REDEMPTION_ROUTER_ADDRESS=0x0000000000000000000000000000000000000000

# SwapRouter Contract (NEW in v3)
SWAP_ROUTER_ADDRESS=0x0000000000000000000000000000000000000000

# LoyaltyToken Contract (PLT)
LOYALTY_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000

# ============================================================
# LEGACY CONTRACT ADDRESSES (v2 - for reference)
# ============================================================

# Old LoyaltyPoint v2 (deprecated)
LOYALTY_POINT_V2_ADDRESS=0x0000000000000000000000000000000000000000

# ============================================================
# EXPLORER LINKS
# ============================================================

# Lisk Sepolia Blockscout Base URL
EXPLORER_BASE_URL=https://sepolia-blockscout.lisk.com/address/

# Contract Explorer Links (will be auto-generated after deployment)
IDRX_EXPLORER=https://sepolia-blockscout.lisk.com/address/0x0000000000000000000000000000000000000000
REWARD_MANAGER_EXPLORER=https://sepolia-blockscout.lisk.com/address/0x0000000000000000000000000000000000000000
REDEMPTION_ROUTER_EXPLORER=https://sepolia-blockscout.lisk.com/address/0x0000000000000000000000000000000000000000
SWAP_ROUTER_EXPLORER=https://sepolia-blockscout.lisk.com/address/0x0000000000000000000000000000000000000000
LOYALTY_TOKEN_EXPLORER=https://sepolia-blockscout.lisk.com/address/0x0000000000000000000000000000000000000000