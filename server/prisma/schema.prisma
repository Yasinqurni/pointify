// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  walletAddress String @unique
  email     String?  @unique
  username  String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Loyalty points balance (off-chain)
  loyaltyPoints Int @default(0)
  
  // Relations
  pointTransactions PointTransaction[]
  redemptions       Redemption[]
  
  @@map("users")
}

model Merchant {
  id        String   @id @default(cuid())
  walletAddress String @unique
  name      String
  description String?
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Merchant quota management
  idrxBalance    Float @default(0)
  loyalBalance   Float @default(0)
  totalRewarded  Float @default(0)
  
  // Relations
  rewards        Reward[]
  pointTransactions PointTransaction[]
  redemptions   Redemption[]
  
  @@map("merchants")
}

model Reward {
  id          String   @id @default(cuid())
  title       String
  description String
  imageUrl    String?
  requiredPoints Int
  expiryDate  DateTime
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  merchantId  String
  merchant    Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  redemptions Redemption[]
  
  @@map("rewards")
}

model PointTransaction {
  id        String   @id @default(cuid())
  amount    Int      // Positive for received, negative for spent
  type      TransactionType
  createdAt DateTime @default(now())

  // Relations
  userId    String
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  merchantId String?
  merchant  Merchant? @relation(fields: [merchantId], references: [id], onDelete: SetNull)
  
  // Optional reference to redemption
  redemptionId String?
  redemption   Redemption? @relation(fields: [redemptionId], references: [id], onDelete: SetNull)
  
  @@map("point_transactions")
}

model Redemption {
  id        String   @id @default(cuid())
  status    RedemptionStatus @default(PENDING)
  claimCode String   @unique
  redeemedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  userId    String
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  rewardId  String
  reward    Reward @relation(fields: [rewardId], references: [id], onDelete: Cascade)
  
  merchantId String
  merchant  Merchant @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  
  // Point transaction for this redemption
  pointTransactions PointTransaction[]
  
  @@map("redemptions")
}

enum TransactionType {
  RECEIVED
  SPENT
  REFUNDED
}

enum RedemptionStatus {
  PENDING
  CLAIMED
  EXPIRED
  CANCELLED
} 